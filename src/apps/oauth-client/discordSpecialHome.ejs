<h1>
  <%= title %>
</h1>
<h2 class='username'></h2>
<article class='user-info'></article>
<article class='guilds'></article>
<article class='dm-channels'></article>
<script type='module'>
  const user = JSON.parse('<%- JSON.stringify(user) %>')
  const guilds = JSON.parse('<%- JSON.stringify(guilds) %>')
  const dmChannels = JSON.parse('<%- JSON.stringify(dmChannels) %>')

  document.querySelector('.username').textContent = user?.global_name || user?.username || ''
  document.querySelector('.user-info').innerHTML = `
    <strong>User ID:</strong> ${user?.id || ''}<br>
    <strong>Username:</strong> ${user?.username || ''}#${user?.discriminator || '0'}<br>
    <strong>Profile:</strong> <a href="https://discord.com/users/${user?.id || ''}" target="_blank">View on Discord</a>
  `
  document.querySelector('.guilds').innerHTML = `
    <strong>Guilds (${guilds?.length || 0}):</strong><br>
    ${guilds?.map((guild) => `
      <div style="margin: 5px 0;">
        ${guild.name}${guild.owner ? ' <span style="color: gold;">(Owner)</span>' : ''}
      </div>
    `).join('') || 'No guilds found'}
  `
  document.querySelector('.dm-channels').innerHTML = `
    <strong>DM Channels (${dmChannels?.length || 0}):</strong><br>
    ${dmChannels?.map((channel) => `
      <div style="margin: 5px 0;">
        ${channel.recipients?.map(r => `${r.username}#${r.discriminator}`).join(', ') || 'Unknown'}
      </div>
    `).join('') || 'No DM channels found'}
  `
</script>
