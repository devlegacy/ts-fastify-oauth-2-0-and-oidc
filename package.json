{
  "$schema": "https://json.schemastore.org/package",
  "name": "ts-fastify-oauth-2-0-and-oidc",
  "version": "1.4.0",
  "description": "",
  "main": "./dist/apps/main.js",
  "type": "module",
  "scripts": {
    "prepare": "husky || true",
    "prebuild": "pnpm run build:clean",
    "build": "swc ./src/ --config-file ./.swcrc.build --out-dir ./dist/ --strip-leading-paths && rsync -avm --include='*.ejs' --include='*/' --exclude='*' ./src/ ./dist/ && ./.bin/replace-import-paths",
    "build:clean": "rm -Rf ./dist; exit 0",
    "start": "node --env-file=.env ./dist/apps/main.js",
    "start:debug": "node --env-file=.env --import @swc-node/register/esm-register --watch --inspect=0.0.0.0:0 ./src/apps/main.ts",
    "lint": "eslint --color \"./src/**/*.ts\"",
    "lint:fix": "pnpm run lint -- --fix",
    "test": "pnpm run test:unit && pnpm run test:features",
    "test:coverage": "c8 pnpm run test:unit && pnpm run test:features",
    "test:features": "node --env-file=.env --import @swc-node/register/esm-register ./node_modules/@cucumber/cucumber/bin/cucumber-js --config ./cucumber.mjs -p app_backend",
    "test:unit": "node --env-file=.env --import @swc-node/register/esm-register --test ./tests/**/*.test.ts"
  },
  "imports": {
    "#@/*": "./*"
  },
  "keywords": [],
  "author": "Samuel R. <jstsamuel@devexteam.com> (https://devexteam.com)",
  "license": "MIT",
  "dependencies": {
    "@fastify/autoload": "5.10.0",
    "@fastify/compress": "7.0.3",
    "@fastify/cookie": "9.4.0",
    "@fastify/cors": "9.0.1",
    "@fastify/view": "9.1.0",
    "convict": "6.2.4",
    "convict-format-with-validator": "6.2.0",
    "dotenv-expand": "11.0.6",
    "ejs": "3.1.10",
    "fast-jwt": "4.0.2",
    "fastify": "4.28.1",
    "http-status": "1.7.4",
    "pino": "9.3.2",
    "pino-pretty": "11.2.2",
    "uuid": "10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.4.0",
    "@commitlint/config-conventional": "19.2.2",
    "@cucumber/cucumber": "10.9.0",
    "@eslint/compat": "1.1.1",
    "@eslint/js": "9.9.0",
    "@stylistic/eslint-plugin": "2.6.4",
    "@swc-node/register": "1.10.9",
    "@swc/cli": "0.4.0",
    "@swc/core": "1.7.14",
    "@types/convict": "6.1.6",
    "@types/convict-format-with-validator": "6.0.5",
    "@types/ejs": "3.1.5",
    "@types/eslint-plugin-security": "3.0.0",
    "@types/eslint__eslintrc": "2.1.2",
    "@types/eslint__js": "8.42.3",
    "@types/node": "22.5.0",
    "@types/supertest": "6.0.2",
    "@types/uuid": "10.0.0",
    "c8": "10.1.2",
    "cz-git": "1.9.4",
    "eslint": "9.9.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-security": "3.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.1.3",
    "globals": "15.9.0",
    "husky": "9.1.5",
    "lint-staged": "15.2.9",
    "replace-in-file": "8.1.0",
    "supertest": "7.0.0",
    "ts-node": "10.9.2",
    "typescript": "5.5.4",
    "typescript-eslint": "8.2.0"
  },
  "engines": {
    "node": ">=22.7.0",
    "npm": ">=10.8.2",
    "pnpm": ">=9.8.0"
  },
  "engineStrict": true,
  "private": true,
  "packageManager": "pnpm@9.8.0+sha512.8e4c3550fb500e808dbc30bb0ce4dd1eb614e30b1c55245f211591ec2cdf9c611cabd34e1364b42f564bd54b3945ed0f49d61d1bbf2ec9bd74b866fcdc723276"
}
