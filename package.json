{
  "$schema": "https://json.schemastore.org/package",
  "name": "ts-fastify-oauth-2-0-and-oidc",
  "version": "1.4.0",
  "description": "",
  "type": "module",
  "scripts": {
    "prepare": "husky || true",
    "prebuild": "node --run build:clean",
    "build": "swc ./src/ --config-file ./.swcrc.build --out-dir ./dist/ --strip-leading-paths && rsync -avm --include='*.ejs' --include='*/' --exclude='*' ./src/ ./dist/ && ./.bin/replace-import-paths",
    "build:clean": "rm -Rf ./dist; exit 0",
    "start": "node --env-file=.env ./dist/apps/oauth-client/main.js",
    "start:client:debug": "node --env-file=.env --import @swc-node/register/esm-register --watch --inspect=0.0.0.0:0 ./src/apps/oauth-client/main.ts",
    "start:server:debug": "node --env-file=.env --import @swc-node/register/esm-register --watch --inspect=0.0.0.0:0 ./src/apps/oauth-server/main.ts",
    "lint": "eslint --color \"./src/**/*.ts\"",
    "lint:fix": "node --run lint -- --fix",
    "test": "node --run test:unit && node --run test:features",
    "test:coverage": "c8 node --run test:unit && node --run test:features",
    "test:features": "node --import @swc-node/register/esm-register ./node_modules/@cucumber/cucumber/bin/cucumber-js --config ./cucumber.js -p oauth_client",
    "test:unit": "node --env-file=.env --import @swc-node/register/esm-register --test ./tests/**/*.test.ts"
  },
  "imports": {
    "#@/*": "./*"
  },
  "keywords": [],
  "author": "Samuel R. <contact@jstsamuel.dev> (https://jstsamuel.dev)",
  "license": "MIT",
  "dependencies": {
    "@fastify/autoload": "6.3.0",
    "@fastify/compress": "8.0.1",
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.0.1",
    "@fastify/formbody": "8.0.2",
    "@fastify/multipart": "9.0.3",
    "@fastify/static": "8.1.1",
    "@fastify/view": "11.0.0",
    "convict": "6.2.4",
    "convict-format-with-validator": "6.2.0",
    "dotenv-expand": "12.0.2",
    "ejs": "3.1.10",
    "fast-jwt": "6.0.1",
    "fastify": "5.3.2",
    "http-status": "2.1.0",
    "jwks-rsa": "3.2.0",
    "oauth2-server": "3.1.1",
    "pino": "9.6.0",
    "pino-pretty": "13.0.0",
    "undici": "7.8.0",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.0",
    "@commitlint/config-conventional": "19.8.0",
    "@cucumber/cucumber": "11.2.0",
    "@eslint/js": "9.25.1",
    "@stylistic/eslint-plugin": "4.2.0",
    "@swc-node/register": "1.10.10",
    "@swc/cli": "0.7.3",
    "@swc/core": "1.11.21",
    "@types/convict": "6.1.6",
    "@types/convict-format-with-validator": "6.0.5",
    "@types/ejs": "3.1.5",
    "@types/eslint-plugin-security": "3.0.0",
    "@types/node": "22.14.1",
    "@types/oauth2-server": "3.0.18",
    "@types/supertest": "6.0.3",
    "@types/uuid": "10.0.0",
    "c8": "10.1.3",
    "cz-git": "1.11.1",
    "eslint": "9.25.1",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-security": "3.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.1.4",
    "globals": "16.0.0",
    "husky": "9.1.7",
    "lint-staged": "15.5.1",
    "replace-in-file": "8.3.0",
    "supertest": "7.1.0",
    "ts-node": "10.9.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.31.0"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10",
    "pnpm": ">=9"
  },
  "engineStrict": true,
  "private": true,
  "packageManager": "pnpm@10.9.0+sha512.0486e394640d3c1fb3c9d43d49cf92879ff74f8516959c235308f5a8f62e2e19528a65cdc2a3058f587cde71eba3d5b56327c8c33a97e4c4051ca48a10ca2d5f"
}
