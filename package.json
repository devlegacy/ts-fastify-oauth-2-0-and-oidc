{
  "$schema": "https://json.schemastore.org/package",
  "name": "ts-fastify-oauth-2-0-and-oidc",
  "version": "1.4.0",
  "description": "",
  "main": "./dist/apps/main.js",
  "type": "module",
  "scripts": {
    "prepare": "husky || true",
    "prebuild": "node --run build:clean",
    "build": "swc ./src/ --config-file ./.swcrc.build --out-dir ./dist/ --strip-leading-paths && rsync -avm --include='*.ejs' --include='*/' --exclude='*' ./src/ ./dist/ && ./.bin/replace-import-paths",
    "build:clean": "rm -Rf ./dist; exit 0",
    "start": "node --env-file=.env ./dist/apps/main.js",
    "start:debug": "node --env-file=.env --import @swc-node/register/esm-register --watch --inspect=0.0.0.0:0 ./src/apps/main.ts",
    "lint": "eslint --color \"./src/**/*.ts\"",
    "lint:fix": "node --run lint -- --fix",
    "test": "node --run test:unit && node --run test:features",
    "test:coverage": "c8 node --run test:unit && node --run test:features",
    "test:features": "node --import @swc-node/register/esm-register ./node_modules/@cucumber/cucumber/bin/cucumber-js --config ./cucumber.js -p app_backend",
    "test:unit": "node --env-file=.env --import @swc-node/register/esm-register --test ./tests/**/*.test.ts"
  },
  "imports": {
    "#@/*": "./*"
  },
  "keywords": [],
  "author": "Samuel R. <jstsamuel@devexteam.com> (https://devexteam.com)",
  "license": "MIT",
  "dependencies": {
    "@fastify/autoload": "6.0.3",
    "@fastify/compress": "8.0.1",
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "10.0.2",
    "@fastify/formbody": "8.0.2",
    "@fastify/multipart": "9.0.2",
    "@fastify/view": "10.0.2",
    "convict": "6.2.4",
    "convict-format-with-validator": "6.2.0",
    "dotenv-expand": "12.0.1",
    "ejs": "3.1.10",
    "fast-jwt": "5.0.2",
    "fastify": "5.2.1",
    "http-status": "2.1.0",
    "jwks-rsa": "3.1.0",
    "pino": "9.6.0",
    "pino-pretty": "13.0.0",
    "uuid": "11.0.5"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@cucumber/cucumber": "11.2.0",
    "@eslint/compat": "1.2.5",
    "@eslint/js": "9.18.0",
    "@stylistic/eslint-plugin": "2.13.0",
    "@swc-node/register": "1.10.9",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.10.7",
    "@types/convict": "6.1.6",
    "@types/convict-format-with-validator": "6.0.5",
    "@types/ejs": "3.1.5",
    "@types/eslint-plugin-security": "3.0.0",
    "@types/eslint__eslintrc": "2.1.2",
    "@types/eslint__js": "8.42.3",
    "@types/node": "22.10.6",
    "@types/supertest": "6.0.2",
    "@types/uuid": "10.0.0",
    "c8": "10.1.3",
    "cz-git": "1.11.0",
    "eslint": "9.18.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-security": "3.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.1.4",
    "globals": "15.14.0",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "replace-in-file": "8.3.0",
    "supertest": "7.0.0",
    "ts-node": "10.9.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10",
    "pnpm": ">=9"
  },
  "engineStrict": true,
  "private": true,
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
