#!/usr/bin/env bash

COLORS_PATH=$(dirname "$0")/../.bin/colors.sh
[ -f "${COLORS_PATH}" ] && source "${COLORS_PATH}"

# Block pushes to protected remote branches regardless of local branch name
while read -r _ _ remote_ref _; do
  if [[ "$remote_ref" =~ refs/heads/(master|main|develop)$ ]]; then
    echo "🚫 ${COLOR_RED}You can't push directly to <${COLOR_YELLOW}${remote_ref#refs/heads/}${COLOR_RED}> branch. Please create a new branch and try again.${COLOR_RESET}"
    exit 1
  fi
done

pnpm run build
pnpm run test
